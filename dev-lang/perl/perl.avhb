pkgname=perl
pkgver=5.30.2
_baseversion="${pkgver%.*}"
pkgrel=1
pkgdesc="A highly capable, feature-rich programming language"
arch=('x86_64')
groups=('dev-lang')
license=('GPL' 'PerlArtistic')
url="https://www.perl.org"
depends=('gdbm' 'db' 'glibc')
