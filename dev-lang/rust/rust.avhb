pkgbase=rust
pkgname=('rust' 'rust-docs')
_realname=rustc
epoch=1
pkgver=1.45.0
pkgrel=1
_llvm_ver=10.0.1
pkgdesc='Systems programming language focused on safety, speed and concurrency'
url='https://www.rust-lang.org/'
arch=('x86_64')
groups=('dev-lang')
license=('MIT' 'Apache')
makedepends=('rust' 'llvm' 'libffi' 'perl' 'python' 'curl' 'cmake')
checkdepends=('procps-ng' 'gdb')
options=('!emptydirs')
source=("https://static.rust-lang.org/dist/rustc-$pkgver-src.tar.gz"{,.asc}
        config.toml)
validpgpkeys=('108F66205EAEB0AAA8DD5E1C85AB96E6FA1BE5FE') # Rust Language (Tag and Release Signing Key) <rust-key@rust-lang.org>

_rust_triplet=x86_64-unknown-linux-gnu

prepare() {
  cd "rustc-$pkgver-src"

  mkdir build
  # mv ../cache build/
}

build() {
  ## approximatly minimum 50 GB free space needed for build
  cd "rustc-$pkgver-src"

  export RUST_BACKTRACE=1

  ./configure --prefix=/usr \
    --libdir=/usr/lib \
    --datadir=/usr/share \
    --infodir=/usr/share/info \
    --build=${_rust_triplet}\
    --host=${_rust_triplet} \
    --target=${_rust_triplet} \
    --cargo = "/usr/bin/cargo" \
    --rustc = "/usr/bin/rustc" \
    --python="/usr/bin/python3" \
    --llvm-root="/usr" \
    --llvm-config="/usr/bin/llvm-config" \
    --enable-llvm-link-shared \
    --enable-extended \
    --enable-vendor \
    --enable-profiler \
    --release-channel=stable \
    --debuginfo-level=2 \
    --codegen-units-std=1 \
    --disable-option-checking \
    --disable-codegen-tests \
    --disable-jemalloc \
    --disable-rpath

	# make ${MAKEFLAGS} VERBOSE=1
  python3 ./x.py dist -j "$(nproc)"
  python3 ./x.py doc
	#--llvm-root=/usr \
	#make CFLAGS="$C
}

package_rust() {
  depends=('gcc-libs' 'llvm-libs' 'curl' 'libssh2')
  provides=('cargo' 'rustfmt')

  cd "rustc-$pkgver-src"

  DESTDIR="$pkgdir" python ./x.py install -j "$(nproc)"

  for license in APACHE MIT; do install -Dm644 "LICENSE-$license" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE-$license"; done

  # delete unnecesary files, e.g. components and manifest files only used for the uninstall script
  cd "$pkgdir"/usr/lib/rustlib
  rm components install.log manifest-* rust-installer-version uninstall.sh

  # rustbuild always installs copies of the shared libraries to /usr/lib,
  # overwrite them with symlinks to the per-architecture versions
  ln -srft "$pkgdir"/usr/lib $_rust_triplet/lib/*.so

  install -d "$pkgdir"/usr/share/bash-completion
  mv "$pkgdir"/etc/bash_completion.d/ "$pkgdir"/usr/share/bash-completion/completions/

  # move docs out of the way for splitting
  mv "$pkgdir"/usr/share/doc "$srcdir"
}

package_rust-docs() {
  install -d "$pkgdir/usr/share/doc/rust/"
  mv "$srcdir"/doc/* "$pkgdir"/usr/share/doc/rust/

  for license in APACHE MIT; do install -Dm644 "rustc-$pkgver-src/LICENSE-$license" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE-$license"; done
}