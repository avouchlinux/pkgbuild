pkgname=python3-pluggy
_realname=pluggy
pkgver=0.13.1
pkgrel=1
pkgdesc="Plugin and hook calling mechanisms for python3"
arch=('any')
groups=('dev-python3')
url="https://www.pluggypayments.com/docs/python3"
license=('MIT')
depends=('python3')
makedepends=('python3-setuptools-scm' 'python3-importlib-metadata')
checkdepends=('python3-pytest-runner')
source=("https://pypi.io/packages/source/p/pluggy/pluggy-$pkgver.zip")

export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver

build() {
  cd $_realname-$pkgver
  python3 setup.py build
}

check() {
  cd $_realname-$pkgver
  python3 setup.py pytest
}

package() {
  cd $_realname-$pkgver
  python3 setup.py install --skip-build --root="${pkgdir}" --optimize='1'
}
