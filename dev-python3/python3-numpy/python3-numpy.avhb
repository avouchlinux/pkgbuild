pkgname=python3-numpy
_realname=numpy
pkgver=1.18.4
pkgrel=1
pkgdesc="Scientific tools for Python"
arch=('x86_64')
groups=('dev-python3')
license=('custom')
url="https://www.numpy.org/"
depends=('cblas' 'lapack' 'python')
optdepends=('python3-nose: testsuite'
            'openblas: faster linear algebra')
makedepends=('python3-setuptools' 'gcc-fortran' 'python3-nose' 'python3-cython')
checkdepends=('python3-pytest')
options=('staticlibs')
source=("https://github.com/numpy/numpy/archive/v$pkgver.tar.gz")

build() {
  cd $_realname-$pkgver
  python3 setup.py build
}

check() {
  # TODO: Fix fortran tests here (it works fine after installation)

  cd numpy-$pkgver
  python setup.py install --root="$PWD/tmp_install" --optimize=1
  cd "$PWD/tmp_install"
  PATH="$PWD/usr/bin:$PATH" PYTHONPATH="$PWD/usr/lib/python3.8/site-packages:$PYTHONPATH" python -c 'import numpy; numpy.test()'
}

package() {
  cd $_realname-$pkgver
  python3 setup.py install --skip-build --root="${pkgdir}" --optimize='1'
  # install missing header file
  install -Dm644 tmp_install/usr/lib/python3.8/site-packages/numpy/core/include/numpy/_numpyconfig.h \
    ${pkgdir}/usr/lib/python3.8/site-packages/numpy/core/include/numpy/_numpyconfig.h
}