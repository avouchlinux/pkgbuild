pkgname=python3-pycrypto
_realname=pycrypto
pkgver=2.6.1
pkgrel=1
pkgdesc="Collection of cryptographic algorithms and protocols, implemented for use from python3"
arch=('x86_64')
groups=('dev-python3')
depends=('python3')
makedepends=('python32' 'python3')
url="http://www.dlitz.net/software/pycrypto/"
license=('custom')
source=(http://ftp.dlitz.net/pub/dlitz/crypto/${pkgbase}/${pkgbase}-${pkgver}.tar.gz)

build() {
  cd ${_realname}-${pkgver}
  python3 setup.py build
}

check() {
  cd ${_realname}-${pkgver}
  python3 setup.py pytest
}

package() {
  cd ${_realname}-${pkgver}
  python3 setup.py install --skip-build --root="${pkgdir}" --optimize='1'
}