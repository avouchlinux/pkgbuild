# Contributor: Qurban Ullah <qurbanullah@avouch.org>

pkgname=python3-cython
_realname=cython
pkgver=0.29.16
pkgrel=1
pkgdesc="C-Extensions for Python3"
arch=('x86_64')
groups=('dev-python3')
url="https://cython.org"
license=(APACHE)
depends=(python-setuptools)
makedepends=(python-setuptools)
source=("https://github.com/cython/cython/archive/$pkgver.tar.gz"
        cython-hash-int-conversion.patch::"https://github.com/cython/cython/commit/28251032.patch")

prepare() {
  cd $_realname-$pkgver
  patch -p1 -i ../cython-hash-int-conversion.patch # Allow non-int conversion to Py_hash_t, needed by sagemath
}

build() {
  cd $_realname-$pkgver
  python3 setup.py build
}

package() {
  cd $_realname-$pkgver
  python3 setup.py install --root="$pkgdir" --skip-build

  for f in cygdb cython cythonize; do
    mv "$pkgdir"/usr/bin/$f "$pkgdir"/usr/bin/${f}3
    ln -s ${f}3 "$pkgdir"/usr/bin/$f
  done
}