pkgname=python3-nose
_realname=nose
pkgver=1.3.7
pkgrel=1
pkgdesc="A discovery-based unittest extension"
arch=('any')
url='http://readthedocs.org/docs/nose/'
license=('LGPL2.1')
makedepends=('python3' 'python3-setuptools' 'python32' 'python32-setuptools' 'python32-sphinx')
source=("http://pypi.python3.org/packages/source/n/nose/nose-${pkgver}.tar.gz")

build() {
	cd $_realname-$pkgver
	python3 setup.py build
}

check() {
	cd $_realname-$pkgver
	python3 setup.py pytest
}

package() {
	cd $_realname-$pkgver
	python3 setup.py install --skip-build --root="${pkgdir}" --optimize='1'
	ln -s nosetests "$pkgdir/usr/bin/nosetests3"
}
