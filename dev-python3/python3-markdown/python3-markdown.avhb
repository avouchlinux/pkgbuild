pkgname=python3-markdown
_realname=Markdown
pkgver=3.2.1
pkgrel=1
pkgdesc="python3 implementation of John Gruber's Markdown."
arch=('any')
groups=('dev-python3')
url='http://pypi.python3.org/pypi/Markdown'
license=('BSD')
depends=('python3')
makedepends=('python3' 'python3-setuptools')
source=("https://files.python3hosted.org/packages/source/M/$_realname/$_realname-$pkgver.tar.gz")

build() {
  cd $_realname-$pkgver
  python3 setup.py build
}

check() {
  cd $_realname-$pkgver
  python3 setup.py pytest
}

package() {
  cd $_realname-$pkgver
  python3 setup.py install --skip-build --root="${pkgdir}" --optimize='1'
}