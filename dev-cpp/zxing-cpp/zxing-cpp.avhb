pkgname=zxing-cpp
pkgver=1.1.0
pkgrel=1
pkgdesc="A command-line tool to decode QRCode"
arch=('x86_64')
groups=('dev-cpp')
url="https://github.com/nu-book/zxing-cpp"
license=(Apache)
depends=(gcc-libs)
makedepends=(cmake)
source=("https://github.com/nu-book/zxing-cpp/archive/v$pkgver.tar.gz")

prepare() {
  cd $pkgname-$pkgver

  # Fix pkg-config file
  # https://github.com/nu-book/zxing-cpp/commit/877b6db1613ddae58e570801920f089c0f64b97f
  # https://github.com/nu-book/zxing-cpp/issues/156
  sed -e 's/@VERSION@/@PROJECT_VERSION@/' \
      -e 's/@TARGET_ZXING@/ZXing/' \
      -i zxing.pc.in
}

build() {
  cmake -S $pkgname-$pkgver -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=None \
    -DBUILD_SHARED_LIBRARY=ON
  ninja -C build
}

package() {
  DESTDIR="$pkgdir" ninja -C build install
}
